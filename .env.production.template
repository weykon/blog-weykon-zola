# France 服务器生产环境配置
# 复制此文件到服务器的 /root/blog.weykon/.env.production

# 数据库配置（使用 Docker 内部网络）
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=请设置强密码
POSTGRES_DB=blog_db
POSTGRES_PORT=5432

# 应用配置
APP_PORT=3000
BASE_URL=https://blog.weykon.com
DEV_MODE=false
RUST_LOG=info

# Google OAuth（从旧服务器复制）
GOOGLE_CLIENT_ID=你的_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=你的_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://blog.weykon.com/auth/google/callback

# 微信 OAuth（如果需要）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# 安全密钥（请生成新的随机字符串）
SESSION_SECRET=请生成32位以上随机字符串
JWT_SECRET=请生成32位以上随机字符串
JWT_EXPIRATION=604800

# pgAdmin 配置
PGADMIN_EMAIL=admin@blog.com
PGADMIN_PASSWORD=请设置强密码
PGADMIN_PORT=5050

# 代理配置（如果需要访问 Google API）
HTTP_PROXY=
HTTPS_PROXY=
