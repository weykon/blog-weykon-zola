# Database Configuration
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=blog_password
POSTGRES_DB=blog_db
POSTGRES_PORT=5432
DATABASE_URL=postgres://blog_user:blog_password@localhost:5432/blog_db

# PgAdmin Configuration
PGADMIN_EMAIL=admin@blog.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Application Configuration
RUST_LOG=debug
APP_HOST=0.0.0.0
APP_PORT=3000
BASE_URL=http://localhost:3000

# OAuth Configuration
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# WeChat OAuth
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_REDIRECT_URI=http://localhost:3000/auth/wechat/callback

# Session Secret
SESSION_SECRET=your_very_secret_session_key_change_this_in_production

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRATION=86400  # 24 hours in seconds
